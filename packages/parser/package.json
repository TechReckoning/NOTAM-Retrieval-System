{
  "name": "@notam/parser",
  "version": "0.1.0",
  "description": "Parses Romanian BAZA NOTAM bulletins into a normalized, geo-referenced NOTAM model.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "sample": "tsx scripts/build-sample.ts",
    "tma": "tsx scripts/build-tma.ts"
  },
  "dependencies": {
    "@turf/turf": "^7.1.0",
    "mammoth": "^1.8.0"
  },
  "devDependencies": {
    "tsx": "^4.16.2",
    "vitest": "^1.6.0"
  }
}
